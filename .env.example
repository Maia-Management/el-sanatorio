# el-sanatorio — Netlify environment variables
# Copy real values into Netlify dashboard → Site settings → Environment variables.
# Never commit a real .env file (it's gitignored).

# ── Supabase (shared Vert OS instance: nxgndsnxugcevwriljlv) ──────────────
SUPABASE_URL=https://nxgndsnxugcevwriljlv.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-settings

# ── WiFi captive portal ───────────────────────────────────────────────────
# Returned to guests after they sign up at /wifi/.
# Set this to the actual WPA2 PSK on the guest SSID ("El Sanatorio Wi-Fi").
# Rotate this in the Netlify dashboard whenever the router password changes.
WIFI_GUEST_PASSWORD=changeme-set-in-netlify-dashboard

# ── Customer identity layer (Google SSO via Supabase Auth) — 2026-06-24 ───
# Required for /api/customer-account-upsert, /api/auth/me, /api/wifi-grant.
#
# The Google OAuth client is created in Google Cloud Console (External consent
# screen — for customer flow, separate from the admin Internal one). Client ID
# + Secret live in Supabase Studio → Authentication → Providers → Google
# (NOT in this env file — Supabase brokers the OAuth round-trip).
#
# This site needs:
#   - SUPABASE_ANON_KEY: public anon key, safe to expose in HTML meta tags.
#   - SUPABASE_JWT_SECRET: project JWT secret. Lets Netlify functions verify
#     session JWTs locally; without it they fall back to a GoTrue /user
#     round-trip per request (slower but still correct).
SUPABASE_ANON_KEY=replace-with-public-anon-key-from-supabase-settings
SUPABASE_JWT_SECRET=replace-with-jwt-secret-from-supabase-settings-API-section
